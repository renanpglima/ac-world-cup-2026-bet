{
	"rules": {
		"reactions": {
			".read": true,
			"$player": {
				"$emoji": {
					"$uid": {
						".write": "auth != null && auth.uid === $uid",
						".validate": "newData.isBoolean()"
					}
				}
			}
		},
		"matches": {
			"reactions": {
				".read": true,
				"$matchId": {
					"$emoji": {
						"$uid": {
							".write": "auth != null && auth.uid === $uid",
							".validate": "newData.isBoolean()"
						}
					}
				}
			}
		},
		"games": {".read": true, ".write": false},
		"demo": {
			".read": true,
			".write": true
		},
		"commentary": {".read": true},
		"cheers": {".read": true, ".write": true},
		"presence": {".read": true, ".write": true},
		"leaderHype": {".read": true, ".write": true}
	}
}
