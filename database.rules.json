// ⚠️ FRAGMENT — NOT a complete ruleset. Do NOT `firebase deploy` this standalone:
// it would replace the whole RTDB ruleset and wipe the existing rules for
// games / commentary / reactions / cheers / presence / leaderHype / demo.
// Merge ONLY the `profiles` and `approvals` blocks below into the current rules
// in the Firebase console (Realtime Database → Rules), leaving the others intact.
// Firebase rules accept these // comments; strict JSON.parse does not.
{
	"rules": {
		"profiles": {
			".read": true,
			"$uid": {
				".write": "auth != null && (auth.uid === $uid || (auth.token.email === 'adriano.interaminense@gmail.com' && auth.token.email_verified === true))",
				"email": {".validate": "newData.isString()"},
				"name": {".validate": "newData.isString()"},
				"photoURL": {".validate": "newData.isString()"},
				"lastSeenAt": {".validate": "newData.isNumber() || newData.isString()"},
				"claim": {".validate": "newData.isString() || !newData.exists()"},
				"$other": {".validate": false}
			}
		},
		"approvals": {
			".read": true,
			"$uid": {
				".write": "auth.token.email === 'adriano.interaminense@gmail.com' && auth.token.email_verified === true"
			}
		}
	}
}
